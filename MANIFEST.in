include CHANGELOG.md
include CODE_OF_CONDUCT.md
include CONTRIBUTING.md
include SECURITY.md
include LICENSE
include README.md
include README.en.md
include index.html
include pyproject.toml

recursive-include docs *.md *.html
recursive-include examples *.html *.txt *.md *.py
recursive-include tests *.py

prune .github
prune .secrets
prune build
prune data
prune dist
prune graphify-out
prune outputs
prune work

global-exclude __pycache__/*
global-exclude *.py[cod]
